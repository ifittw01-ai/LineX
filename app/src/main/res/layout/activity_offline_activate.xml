<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fff8f4fb"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="離線啟動"
            android:textColor="#ff222222"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="請把下列產品序號傳給供應商取得啟動碼："
            android:textColor="#ff555555"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvSerial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#00ffffff"
            android:padding="10dp"
            android:text="SERIAL"
            android:textColor="#ff333333"
            android:textIsSelectable="true"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCopySerial"
            android:layout_width="160dp"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#ff6f50b8"
            android:text="複製序號"
            android:textColor="#ffffffff"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etActivation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:background="@android:color/transparent"
            android:hint="貼上啟動碼（AC1.xxxxx.yyyyy）"
            android:inputType="textVisiblePassword|textNoSuggestions"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:singleLine="true"
            android:textColor="#ff222222"
            android:textColorHint="#ff999999"
            android:textSize="19sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ff444444" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPaste"
                android:layout_width="160dp"
                android:layout_height="56dp"
                android:backgroundTint="#ff6f50b8"
                android:text="貼上"
                android:textColor="#ffffffff"
                android:textSize="20sp" />

            <Space
                android:layout_width="24dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnActivate"
                android:layout_width="160dp"
                android:layout_height="56dp"
                android:backgroundTint="#ff6f50b8"
                android:text="啟動"
                android:textColor="#ffffffff"
                android:textSize="20sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="※ 啟動碼離線驗證並綁定此裝置，重新安裝通常會產生新序號。"
            android:textColor="#ff666666"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
