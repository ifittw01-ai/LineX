<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.linecommunityjoiner">

    <queries>
        <package android:name="jp.naver.line.android" />
        <package android:name="jp.naver.line.androii" />
        <package android:name="jp.naver.line.androij" />
        <package android:name="jp.naver.line.androik" />
        <package android:name="jp.naver.line.androil" />
        <package android:name="jp.naver.line.androim" />
        <package android:name="jp.naver.line.androin" />
        <package android:name="jp.naver.line.androio" />
        <package android:name="jp.naver.line.androip" />
        <package android:name="jp.naver.line.androiq" />
        <package android:name="jp.naver.line.androir" />
        <package android:name="jp.naver.line.androis" />
        <package android:name="jp.naver.line.androit" />
        <package android:name="jp.naver.line.androiu" />
        <package android:name="jp.naver.line.androiv" />
        <package android:name="jp.naver.line.androiw" />
        <package android:name="jp.naver.line.androix" />
        <package android:name="jp.naver.line.androiy" />
        <package android:name="jp.naver.line.androiz" />
        <package android:name="jp.naver.line.androi0" />
        <package android:name="jp.naver.line.androi1" />
    </queries>

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <permission
        android:name="com.example.linecommunityjoiner.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />
    <uses-permission android:name="com.example.linecommunityjoiner.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LineCommunityJoiner">

        <activity
            android:name=".EntryActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".OfflineActivateActivity" android:exported="false" />
        <activity android:name=".MainActivity" android:exported="false" />

        <service
            android:name=".CommunityJoinAccessibilityService"
            android:exported="false"
            android:label="@string/accessibility_service_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/community_accessibility_service" />
        </service>
    </application>

</manifest>
